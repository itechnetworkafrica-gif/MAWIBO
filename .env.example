# ============================================================================
# MAWIBO — Environment Variables Reference
# ============================================================================
# Copy this file to .env (never commit .env to git).
# All variables marked [REQUIRED] must be set for the app to function.
# Variables marked [OPTIONAL] have sane defaults if omitted.

# ─── API Server ──────────────────────────────────────────────────────────────

# PostgreSQL connection string [REQUIRED]
# Vercel: add this under Project → Settings → Environment Variables
# Neon:   postgres://user:pass@host/dbname?sslmode=require
# Supabase: postgres://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/mawibo

# OpenAI API key — required for AI Chat & AI Hub features [REQUIRED]
OPENAI_API_KEY=sk-...

# Port the API server listens on [OPTIONAL — defaults vary by platform]
PORT=3001

# Session secret — random 32+ char string [REQUIRED]
SESSION_SECRET=change-me-to-a-random-32-character-string

# Comma-separated allowed CORS origins in production [OPTIONAL]
# Leave empty to block all cross-origin requests (recommended if frontend
# and API are served from the same domain).
# Example: https://mawibo.vercel.app,https://app.mawibo.com
CORS_ORIGIN=

# Log level: trace | debug | info | warn | error | fatal [OPTIONAL]
LOG_LEVEL=info

# ─── Frontend (Vite / Vercel) ─────────────────────────────────────────────

# Full URL of the deployed API server [OPTIONAL]
# Set this when the frontend and API are on different domains.
# Leave empty when both are served from the same origin.
# Example (separate deployments):
#   VITE_API_URL=https://mawibo-api.railway.app
VITE_API_URL=

# Base path for the frontend app [OPTIONAL — defaults to /]
# Only needed when deploying under a sub-path (e.g. /app).
BASE_PATH=/
